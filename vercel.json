{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/wp-admin/(.*)",
      "dest": "/wp-admin/index.php"
    },
    {
      "src": "/wp-includes/(.*)",
      "dest": "/wp-includes/$1"
    },
    {
      "src": "/wp-content/(.*)",
      "dest": "/wp-content/$1"
    },
    {
      "src": "/(.*\\.php)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}