{
  "name": "wordpress-site",
  "version": 2,
  "builds": [
    {
      "src": "/*.php",
      "use": "@vercel/php"
    },
    {
      "src": "/wp-content/**",
      "use": "@vercel/static"
    },
    {
      "src": "/wp-includes/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/wp-admin/?(.*)",
      "dest": "/wp-admin/index.php"
    },
    {
      "src": "/wp-login.php",
      "dest": "/wp-login.php"
    },
    {
      "src": "/(.*\\.php)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ],
  "env": {
    "WORDPRESS_DB_NAME": "@wordpress_db_name",
    "WORDPRESS_DB_USER": "@wordpress_db_user",
    "WORDPRESS_DB_PASSWORD": "@wordpress_db_password",
    "WORDPRESS_DB_HOST": "@wordpress_db_host"
  }
}